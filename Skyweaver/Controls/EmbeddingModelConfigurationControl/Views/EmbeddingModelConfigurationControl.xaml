<UserControl x:Class="Skyweaver.Controls.EmbeddingModelConfigurationControl.Views.EmbeddingModelConfigurationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Skyweaver.Controls.EmbeddingModelConfigurationControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.EmbeddingModelConfigurationControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:EmbeddingModelConfigurationControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="760"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="ConfigurationListViewStyle"
               TargetType="ListView"
               BasedOn="{StaticResource AeroListViewStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="ConfigurationListViewItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource AeroListViewItemStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <Border x:Name="HoverOverlay"
                                    Background="{StaticResource MenuItemHoverBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="SelectedOverlay"
                                    Background="{StaticResource MenuItemClickedBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" TargetName="HoverOverlay" Value="0.2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Opacity" TargetName="SelectedOverlay" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCardBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ChatSessionHeaderBorderStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="CapsuleBorderStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <DataTemplate x:Key="EmbeddingModelEditorTemplate"
                      DataType="{x:Type models:EmbeddingModelDefinition}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,12,12">
                        <TextBlock Text="显示名称"
                                   FontWeight="SemiBold"/>
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,12">
                        <TextBlock Text="接口类型"
                                   FontWeight="SemiBold"/>
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding DataContext.AvailableInterfaceTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding InterfaceType, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,12,0">
                        <TextBlock Text="向量维度"
                                   FontWeight="SemiBold"/>
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding Dimensions, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1">
                        <TextBlock Text="最大输入 Token"
                                   FontWeight="SemiBold"/>
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding MaxInputTokens, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <WrapPanel Grid.Row="1"
                           Margin="0,0,0,12">
                    <CheckBox Margin="0,0,18,0"
                              IsChecked="{Binding Normalize, UpdateSourceTrigger=PropertyChanged}"
                              Content="归一化向量"/>
                    <CheckBox Margin="0,0,18,0"
                              IsChecked="{Binding SupportsMultimodalEmbedding, UpdateSourceTrigger=PropertyChanged}"
                              Content="支持多模态嵌入"/>
                    <CheckBox IsEnabled="{Binding SupportsMultimodalEmbedding}"
                              IsChecked="{Binding IncludeBinaryDataInTextProjection, UpdateSourceTrigger=PropertyChanged}"
                              Content="在保留内容投影中包含二进制数据"/>
                </WrapPanel>

                <TextBlock Grid.Row="2"
                           Text="{Binding DataContext.InterfaceSettingsSectionTitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontWeight="SemiBold"
                           FontSize="13"/>

                <ContentControl Grid.Row="3"
                                Margin="0,10,0,0"
                                Content="{Binding InterfaceSettings}"/>

                <Grid Grid.Row="4"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="96"
                            Height="32"
                            Command="{Binding TestCommand}"
                            Content="测试模型"/>

                    <Button Grid.Column="2"
                            Width="96"
                            Height="32"
                            Command="{Binding CancelTestCommand}"
                            Content="中止测试"/>

                    <TextBox Grid.Column="4"
                             MinHeight="72"
                             Padding="8,6"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Text="{Binding TestResponse, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:OpenAiEmbeddingModelSettings}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <TextBlock Text="模型 ID"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ModelId, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,12">
                    <TextBlock Text="API Key"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ApiKey, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,0">
                    <TextBlock Text="Base URL"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding BaseUrl, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1">
                    <TextBlock Text="User"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding User, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:GoogleEmbeddingModelSettings}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <TextBlock Text="模型 ID"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ModelId, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,12">
                    <TextBlock Text="API Key"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ApiKey, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <TextBlock Text="Base URL"
                               FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding BaseUrl, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,0,12">
                    <CheckBox IsChecked="{Binding UseTaskType, UpdateSourceTrigger=PropertyChanged}"
                              Content="传入 Task Type"/>
                    <ComboBox Margin="0,6,0,0"
                              IsEnabled="{Binding UseTaskType}"
                              ItemsSource="{Binding SupportedTaskTypes}"
                              SelectedItem="{Binding TaskType, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <CheckBox Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          IsChecked="{Binding SendInlineData, UpdateSourceTrigger=PropertyChanged}"
                          Content="向 Google 请求发送 inlineData"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DocumentTabBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,16">
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource AeroTextBlockStyle}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding Description}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0"
                               Margin="0,0,12,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,10"
                                   Text="嵌入模型列表"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <Grid DockPanel.Dock="Top"
                              Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Command="{Binding AddEmbeddingModelCommand}"
                                    Content="新增"/>
                            <Button Grid.Column="2"
                                    Command="{Binding DuplicateEmbeddingModelCommand}"
                                    Content="复制"/>
                            <Button Grid.Column="4"
                                    Command="{Binding RemoveEmbeddingModelCommand}"
                                    Content="删除"/>
                        </Grid>

                        <Border CornerRadius="2"
                                BorderThickness="1"
                                Padding="4"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.10059,1.65236"
                                                     EndPoint="2.53982,1.65236"
                                                     Opacity="0.5">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform CenterX="0.10059"
                                                           CenterY="1.65236"
                                                           AngleX="-59.7491"
                                                           AngleY="0"/>
                                            <RotateTransform CenterX="0.10059"
                                                             CenterY="1.65236"
                                                             Angle="-70.8836"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop Color="#3BFFFFFF" Offset="0"/>
                                    <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                                    <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                                    <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                                    <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                                    <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                                    <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                                    <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                                    <GradientStop Color="#44FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#40000000"/>
                            </Border.BorderBrush>

                            <ListView ItemsSource="{Binding EmbeddingModels}"
                                  SelectedItem="{Binding SelectedEmbeddingModel}"
                                  Style="{StaticResource ConfigurationListViewStyle}"
                                  ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GlassCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <WrapPanel Margin="0,10,0,0">
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding SummaryModelId, StringFormat=模型 ID: {0}}"/>
                                                </Border>
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding InterfaceType, StringFormat=接口: {0}}"/>
                                                </Border>
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding DimensionsText, StringFormat=维度: {0}}"/>
                                                </Border>
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding MultimodalEmbeddingSupportText, StringFormat=多模态: {0}}"/>
                                                </Border>
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding ConfigurationStatusText, StringFormat=状态: {0}}"/>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </DockPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Margin="0,0,0,10"
                                   Text="嵌入模型配置"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>

                        <Border Grid.Row="1"
                                Style="{StaticResource GlassCardBorderStyle}">
                            <Grid>
                                <ContentControl Content="{Binding SelectedEmbeddingModel}"
                                                ContentTemplate="{StaticResource EmbeddingModelEditorTemplate}"/>
                                <TextBlock Text="从左侧选择一个嵌入模型后，在这里统一编辑它的配置。"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedEmbeddingModel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <DockPanel Grid.Row="2">
                    <Button DockPanel.Dock="Right"
                            Width="120"
                            Margin="12,0,0,0"
                            Command="{Binding OpenConfigurationDirectoryCommand}"
                            Content="打开目录"/>
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding EmbeddingModelConfigurationFilePath}"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
