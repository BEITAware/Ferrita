<UserControl x:Class="Skyweaver.Controls.ShellChatSessionControl.Views.ShellChatSessionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Skyweaver.Controls.ShellChatSessionControl.Views"
             xmlns:models="clr-namespace:Skyweaver.Controls.ShellChatSessionControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.ShellChatSessionControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ShellChatSessionControlViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="360"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- 高度透明的 Aero 聊天气泡背景画笔 -->
        <LinearGradientBrush x:Key="ShellChatUserBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#552B5B75" Offset="0"/>
            <GradientStop Color="#15122F42" Offset="0.35"/>
            <GradientStop Color="#4515324A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellChatAssistantBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#55395A6E" Offset="0"/>
            <GradientStop Color="#150E2838" Offset="0.35"/>
            <GradientStop Color="#45122530" Offset="1"/>
        </LinearGradientBrush>

        <!-- 亮光和发光层，调低透明度实现高透 -->
        <LinearGradientBrush x:Key="ShellChatBubbleTopSheenBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#30FFFFFF" Offset="0"/>
            <GradientStop Color="#10FFFFFF" Offset="0.48"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellChatBubbleBottomGlowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#001878A8" Offset="0"/>
            <GradientStop Color="#0A1E6585" Offset="0.42"/>
            <GradientStop Color="#25248596" Offset="1"/>
        </LinearGradientBrush>

        <!-- 气泡描边和基本阴影 -->
        <Style x:Key="ShellChatMessageBubbleBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#4080C0D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1.5" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶部操作栏小按钮样式 -->
        <!-- 消息的 DataTemplate 定义 -->
        <DataTemplate x:Key="ShellUserMessageTemplate" DataType="{x:Type models:ShellChatMessageModel}">
            <Grid Margin="0,0,0,14"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                  HorizontalAlignment="Stretch"
                  ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="42"/>
                </Grid.ColumnDefinitions>

                <!-- 用户气泡靠右 -->
                <Border Grid.Column="0"
                        HorizontalAlignment="Right"
                        MaxWidth="260"
                        Margin="30,0,8,0"
                        Style="{StaticResource ShellChatMessageBubbleBorderStyle}"
                        Background="{StaticResource ShellChatUserBubbleBackgroundBrush}">
                    <Grid>
                        <!-- 高透亮光叠加层 -->
                        <Border Height="20"
                                Margin="1"
                                VerticalAlignment="Top"
                                CornerRadius="11,11,4,4"
                                Background="{StaticResource ShellChatBubbleTopSheenBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.5"/>
                        <Border Height="12"
                                Margin="1"
                                VerticalAlignment="Bottom"
                                CornerRadius="0,0,11,11"
                                Background="{StaticResource ShellChatBubbleBottomGlowBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.6"/>
                        
                        <StackPanel Margin="12,9">
                            <TextBlock Text="{Binding Content}"
                                       Foreground="White"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                                       Foreground="#50FFFFFF"
                                       FontSize="9"
                                       HorizontalAlignment="Right"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 头像（盈超椭圆，使用正常聊天会话的 Aero 玻璃底图） -->
                <Border Grid.Column="1"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,2,0,0"
                        CornerRadius="12"
                        Background="{DynamicResource ChatAvatarBackgroundGlassBrush}">
                    <Border CornerRadius="10" Margin="2" ClipToBounds="True">
                        <Image Source="{Binding AvatarPath, FallbackValue='pack://application:,,,/Resources/QuestionBot.png'}" Stretch="Uniform"/>
                    </Border>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ShellAssistantMessageTemplate" DataType="{x:Type models:ShellChatMessageModel}">
            <Grid Margin="0,0,0,14"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                  HorizontalAlignment="Stretch"
                  ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 头像（盈超椭圆，使用正常聊天会话的 Aero 玻璃底图） -->
                <Border Grid.Column="0"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        Margin="0,2,0,0"
                        CornerRadius="12"
                        Background="{DynamicResource ChatAvatarBackgroundGlassBrush}">
                    <Border CornerRadius="10" Margin="2" ClipToBounds="True">
                        <Image Source="{Binding AvatarPath, FallbackValue='pack://application:,,,/Resources/GuideBot.png'}" Stretch="Uniform"/>
                    </Border>
                </Border>

                <!-- 助手气泡靠左 -->
                <Border Grid.Column="1"
                        HorizontalAlignment="Left"
                        MaxWidth="260"
                        Margin="8,0,30,0"
                        Style="{StaticResource ShellChatMessageBubbleBorderStyle}"
                        Background="{StaticResource ShellChatAssistantBubbleBackgroundBrush}">
                    <Grid>
                        <!-- 高透亮光叠加层 -->
                        <Border Height="20"
                                Margin="1"
                                VerticalAlignment="Top"
                                CornerRadius="11,11,4,4"
                                Background="{StaticResource ShellChatBubbleTopSheenBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.4"/>
                        <Border Height="12"
                                Margin="1"
                                VerticalAlignment="Bottom"
                                CornerRadius="0,0,11,11"
                                Background="{StaticResource ShellChatBubbleBottomGlowBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.5"/>

                        <StackPanel Margin="12,9">
                            <TextBlock Text="{Binding Content}"
                                       Foreground="#FFE2F3FA"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                                       Foreground="#45FFFFFF"
                                       FontSize="9"
                                       HorizontalAlignment="Left"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <local:ShellChatMessageTemplateSelector x:Key="ShellChatMessageTemplateSelector"
                                                UserTemplate="{StaticResource ShellUserMessageTemplate}"
                                                AssistantTemplate="{StaticResource ShellAssistantMessageTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部控制面板 -->
            <!-- 向上渐隐的聊天记录 -->
            <RowDefinition Height="*"/>
            <!-- 用户输入区域 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部控制面板 -->
        <!-- 聊天消息历史 -->
        <Grid Grid.Row="0" Margin="8,4,8,8">
            <ListBox x:Name="MessagesListBox"
                     VerticalAlignment="Bottom"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding Messages}"
                     ItemTemplateSelector="{StaticResource ShellChatMessageTemplateSelector}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     ScrollViewer.CanContentScroll="False"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     Padding="0,12,0,0">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                ClipToBounds="True">
                            <ScrollViewer Focusable="False"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Hidden"
                                          CanContentScroll="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- 底部输入框和发送栏 -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="#258CB8CD"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12"
                Padding="10,10,10,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </Grid.Resources>

                    <TextBox x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             MaxHeight="80"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             AcceptsReturn="True"
                             KeyDown="InputTextBox_KeyDown"/>

                    <TextBlock x:Name="placeholder"
                               Text="输入消息，按下 Send 发送..."
                               Foreground="#55FFFFFF"
                               FontSize="13"
                               Margin="{Binding Padding, ElementName=InputTextBox}"
                               IsHitTestVisible="False"
                               VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- 发送按钮 -->
                <Button Grid.Column="1"
                        Style="{StaticResource ChatSessionSendButtonStyle}"
                        Command="{Binding SendCommand}"
                        Content="{DynamicResource ShellChat.Button.Send}"
                        Width="64"
                        Height="32"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
